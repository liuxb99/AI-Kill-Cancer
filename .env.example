# AI-Kill-Cancer — Environment Configuration
# Copy this file to .env and fill in your values

# Application
APP_MODE=production
DEBUG=false
LOG_LEVEL=INFO

# Database
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_this_password
DB_NAME=cancer_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Authentication (REQUIRED in production)
JWT_SECRET_KEY=generate_a_random_64_char_secret_key_here

# CORS
CORS_ORIGINS=http://localhost,http://localhost:80

# API
API_PORT=8000
FRONTEND_PORT=80

# Model
MODEL_ENABLED=false
MODEL_PATH=/app/models/cancer_prediction.pkl
